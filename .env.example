# =============================================================================
# StadiumIQ – Environment Variables Template
# Copy this file to .env and fill in your values
# NEVER commit .env to git
# =============================================================================

# APPLICATION
NODE_ENV=development
APP_NAME=StadiumIQ
APP_VERSION=1.0.0
APP_PORT=3001
FRONTEND_URL=http://localhost:3000

# DATABASE (PostgreSQL via Supabase or local)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# REDIS
REDIS_URL=redis://default:PASSWORD@HOST:PORT
REDIS_PASSWORD=your_redis_password
REDIS_DB=0
REDIS_TTL_SECONDS=3600

# JWT (generate with: openssl rand -hex 64)
JWT_ACCESS_SECRET=your_64_char_random_secret_here
JWT_REFRESH_SECRET=your_different_64_char_random_secret_here
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# GOOGLE OAUTH
# From: https://console.cloud.google.com → APIs & Services → Credentials
# Redirect URI: http://localhost:3001/api/v1/auth/google/callback
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3001/api/v1/auth/google/callback

# AI – GOOGLE GEMINI
# From: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-1.5-pro
GEMINI_EMBEDDING_MODEL=text-embedding-004
GEMINI_MAX_TOKENS=2048
GEMINI_TEMPERATURE=0.3

# AI – OPENAI (Optional fallback)
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o

# VECTOR DATABASE (Qdrant)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=optional_local_key
QDRANT_COLLECTION_FIFA=fifa_knowledge_base

# AI SERVICE
AI_SERVICE_URL=http://localhost:8000
AI_SERVICE_API_KEY=your_ai_service_token

# MAPBOX (for indoor navigation maps)
# From: https://account.mapbox.com/
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your_mapbox_public_token

# RATE LIMITING
THROTTLE_FAN_LIMIT=60
THROTTLE_FAN_TTL=60000
THROTTLE_STAFF_LIMIT=300
THROTTLE_STAFF_TTL=60000
THROTTLE_AI_LIMIT=20
THROTTLE_AI_TTL=60000

# ENCRYPTION
ENCRYPTION_KEY=your_32_char_hex_key_here_0123456

# LOGGING
LOG_LEVEL=info
LOG_FORMAT=json

# MONITORING
OTEL_SERVICE_NAME=stadiumiq-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
SENTRY_DSN=optional_sentry_dsn

# NEXT.JS FRONTEND
NEXT_PUBLIC_API_URL=http://localhost:3001/api
NEXT_PUBLIC_AI_SERVICE_URL=http://localhost:3001/api/ai
NEXT_PUBLIC_WS_URL=ws://localhost:3001
NEXT_PUBLIC_APP_ENV=development

# NVIDIA NIM (Optional)
NVIDIA_API_KEY=nvapi-your_nvidia_api_key

# SUPABASE
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key
SUPABASE_SECRET_KEY=your_secret_key
SUPABASE_JWKS_URL=https://your-project.supabase.co/auth/v1/.well-known/jwks.json
